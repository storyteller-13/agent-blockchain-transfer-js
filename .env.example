# Resend: create API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email to receive transfer alerts (required)
NOTIFY_EMAIL=you@example.com

# From address: use a verified domain in production (https://resend.com/domains)
# For testing you can use: Alerts <onboarding@resend.dev>
FROM_EMAIL=Alerts <onboarding@resend.dev>

# Addresses to watch: copy config.example.json to config.json and add bitcoin/ethereum arrays there.
# Optional: path to config file (default: config.json in project root)
CONFIG_PATH=./config.json

# Ethereum RPC URL (optional; defaults to public endpoint; use Alchemy/Infura for production)
# ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Poll interval in seconds (default 30)
# POLL_INTERVAL_SEC=30

# Zcash: Blockchair may rate-limit. Set BLOCKCHAIR_API_KEY (contact info@blockchair.com) or disable:
# DISABLE_ZCASH=1
# BLOCKCHAIR_API_KEY=your_key
